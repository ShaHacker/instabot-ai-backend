# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/instabot_ai
DATABASE_URL_SYNC=postgresql://user:password@localhost:5432/instabot_ai

# JWT
SECRET_KEY=your-super-secret-key-change-this
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Google Gemini
GEMINI_API_KEY=your-gemini-api-key

# Instagram / Meta
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
META_WEBHOOK_VERIFY_TOKEN=your-webhook-verify-token
INSTAGRAM_REDIRECT_URI=http://localhost:8000/api/v1/auth/instagram/callback

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Server
HOST=0.0.0.0
PORT=8000
